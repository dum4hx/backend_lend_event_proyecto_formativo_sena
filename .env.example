PORT=8080

# DB
DB_CONNECTION_STRING=#mongodb connection string here

# JWT
JWT_ASYMMETRIC_KEY_ALG=RS256
JWT_ENC=A256GCM
JWT_ISSUER=https://api.test.local/
JWT_AUDIENCE=https://app.test.local/
JWT_ACCESS_EXPIRATION=60m
JWT_REFRESH_EXPIRATION=30d

COOKIE_DOMAIN=test.local
CORS_ORIGIN=https://api.test.local,https://app.test.local

# --- BILLING ---#
# Stripe API keys
STRIPE_SECRET_KEY=#your stripe secret key here
STRIPE_WEBHOOK_SECRET=#your stripe webhook secret here

# --- EMAIL (SMTP) ---#
# SMTP configuration for transactional emails (password reset, invitations, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=#your SMTP username/email here
SMTP_PASS=#your SMTP password or app-specific password here
SMTP_FROM=noreply@lendevent.com

# Super admin credentials
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# Environment settings
NODE_ENV=development
SKIP_SUBSCRIPTION_CHECK=false